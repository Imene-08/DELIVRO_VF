generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model alertes_stock {
  id         String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  produit_id String       @db.Uuid
  niveau     niveau_stock
  quantite   Int
  message    String?
  lu         Boolean?     @default(false)
  cree_le    DateTime?    @default(now()) @db.Timestamptz(6)
  produits   produits     @relation(fields: [produit_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([lu], map: "idx_alertes_lu")
  @@index([produit_id], map: "idx_alertes_produit")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model bons_livraison {
  id                                       String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  numero_bon                               Int                   @default(autoincrement())
  commande_id                              String                @db.Uuid
  client_nom                               String?               @db.VarChar(200)
  client_telephone                         String?               @db.VarChar(30)
  client_adresse                           String?
  client_ville                             String?               @db.VarChar(100)
  expediteur_nom                           String?               @db.VarChar(200)
  expediteur_adresse                       String?
  expediteur_telephone                     String?               @db.VarChar(30)
  statut                                   statut_bon?           @default(en_attente)
  motif_retour                             String?
  note_livraison                           String?
  date_livraison_prevue                    DateTime?             @db.Date
  date_livraison_reelle                    DateTime?             @db.Timestamptz(6)
  admin_id                                 String                @db.Uuid
  cree_le                                  DateTime?             @default(now()) @db.Timestamptz(6)
  comptes_bons_livraison_admin_idTocomptes comptes               @relation("bons_livraison_admin_idTocomptes", fields: [admin_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  commandes                                commandes             @relation(fields: [commande_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  livraisons_livreurs                      livraisons_livreurs[]
}

model categories {
  id          String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nom         String     @db.VarChar(100)
  description String?
  admin_id    String     @db.Uuid
  cree_le     DateTime?  @default(now()) @db.Timestamptz(6)
  comptes     comptes    @relation(fields: [admin_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  produits    produits[]
}

model clients {
  id        String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nom       String      @db.VarChar(150)
  telephone String?     @db.VarChar(30)
  adresse   String?
  ville     String?     @db.VarChar(100)
  email     String?     @db.VarChar(150)
  admin_id  String      @db.Uuid
  cree_le   DateTime?   @default(now()) @db.Timestamptz(6)
  comptes   comptes     @relation(fields: [admin_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  commandes commandes[]
  factures  factures[]
}

model commandes {
  id                                  String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  numero                              Int               @default(autoincrement())
  client_id                           String?           @db.Uuid
  lieu_id                             String?           @db.Uuid
  statut                              statut_commande?  @default(brouillon)
  note                                String?
  total_ht                            Decimal?          @default(0) @db.Decimal(12, 2)
  total_ttc                           Decimal?          @default(0) @db.Decimal(12, 2)
  cree_par                            String            @db.Uuid
  admin_id                            String            @db.Uuid
  cree_le                             DateTime?         @default(now()) @db.Timestamptz(6)
  modifie_le                          DateTime?         @default(now()) @db.Timestamptz(6)
  bons_livraison                      bons_livraison[]
  comptes_commandes_admin_idTocomptes comptes           @relation("commandes_admin_idTocomptes", fields: [admin_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  clients                             clients?          @relation(fields: [client_id], references: [id], onUpdate: NoAction)
  comptes_commandes_cree_parTocomptes comptes           @relation("commandes_cree_parTocomptes", fields: [cree_par], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lieux                               lieux?            @relation(fields: [lieu_id], references: [id], onUpdate: NoAction)
  factures                            factures[]
  lignes_commande                     lignes_commande[]
  transactions                        transactions[]

  @@index([admin_id], map: "idx_commandes_admin")
  @@index([statut], map: "idx_commandes_statut")
}

model comptes {
  id                                              String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nom                                             String                @db.VarChar(100)
  prenom                                          String?               @db.VarChar(100)
  email                                           String                @unique @db.VarChar(150)
  telephone                                       String?               @db.VarChar(30)
  mot_de_passe                                    String
  role                                            role_compte
  statut                                          statut_compte?        @default(actif)
  admin_parent_id                                 String?               @db.Uuid
  cree_le                                         DateTime?             @default(now()) @db.Timestamptz(6)
  modifie_le                                      DateTime?             @default(now()) @db.Timestamptz(6)
  abonnements                                     abonnements?
  bons_livraison_bons_livraison_admin_idTocomptes bons_livraison[]      @relation("bons_livraison_admin_idTocomptes")
  categories                                      categories[]
  clients                                         clients[]
  commandes_commandes_admin_idTocomptes           commandes[]           @relation("commandes_admin_idTocomptes")
  commandes_commandes_cree_parTocomptes           commandes[]           @relation("commandes_cree_parTocomptes")
  comptes                                         comptes?              @relation("comptesTocomptes", fields: [admin_parent_id], references: [id], onUpdate: NoAction)
  other_comptes                                   comptes[]             @relation("comptesTocomptes")
  factures                                        factures[]
  lieux                                           lieux[]
  livraisons_livreurs                             livraisons_livreurs[]
  produits                                        produits[]
  transactions_transactions_admin_idTocomptes     transactions[]        @relation("transactions_admin_idTocomptes")
  transactions_transactions_cree_parTocomptes     transactions[]        @relation("transactions_cree_parTocomptes")

  @@index([role], map: "idx_comptes_role")
  @@index([statut], map: "idx_comptes_statut")
}

model abonnements {
  id            String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  admin_id      String            @unique @db.Uuid
  plan          plan_abonnement
  prix_mensuel  Decimal           @db.Decimal(12, 2)
  statut        statut_abonnement @default(actif)
  date_debut    DateTime          @default(now()) @db.Timestamptz(6)
  date_echeance DateTime          @db.Timestamptz(6)
  cree_le       DateTime?         @default(now()) @db.Timestamptz(6)
  modifie_le    DateTime?         @default(now()) @db.Timestamptz(6)
  comptes       comptes           @relation(fields: [admin_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model factures {
  id             String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  numero_facture Int             @default(autoincrement())
  commande_id    String          @db.Uuid
  client_id      String?         @db.Uuid
  montant_ht     Decimal         @db.Decimal(12, 2)
  tva_pourcent   Decimal?        @default(0) @db.Decimal(5, 2)
  montant_ttc    Decimal         @db.Decimal(12, 2)
  statut         statut_facture? @default(brouillon)
  date_emission  DateTime?       @default(dbgenerated("CURRENT_DATE")) @db.Date
  date_echeance  DateTime?       @db.Date
  note           String?
  admin_id       String          @db.Uuid
  cree_le        DateTime?       @default(now()) @db.Timestamptz(6)
  comptes        comptes         @relation(fields: [admin_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  clients        clients?        @relation(fields: [client_id], references: [id], onUpdate: NoAction)
  commandes      commandes       @relation(fields: [commande_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model lignes_commande {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  commande_id   String    @db.Uuid
  produit_id    String    @db.Uuid
  quantite      Int
  prix_unitaire Decimal   @db.Decimal(12, 2)
  sous_total    Decimal?  @db.Decimal(12, 2)
  commandes     commandes @relation(fields: [commande_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  produits      produits  @relation(fields: [produit_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model produits {
  id              String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  reference       String            @unique @db.VarChar(100)
  nom             String            @db.VarChar(200)
  description     String?
  prix_achat      Decimal?          @default(0) @db.Decimal(12, 2)
  prix_vente      Decimal           @db.Decimal(12, 2)
  quantite_stock  Int               @default(0)
  seuil_bas       Int               @default(5)
  seuil_moyen     Int               @default(20)
  seuil_plein     Int               @default(50)
  attributs       Json?
  niveau_actuel   niveau_stock?
  categorie_id    String?           @db.Uuid
  lieu_id         String?           @db.Uuid
  admin_id        String            @db.Uuid
  cree_le         DateTime?         @default(now()) @db.Timestamptz(6)
  modifie_le      DateTime?         @default(now()) @db.Timestamptz(6)
  alertes_stock   alertes_stock[]
  lignes_commande lignes_commande[]
  comptes         comptes           @relation(fields: [admin_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  categories      categories?       @relation(fields: [categorie_id], references: [id], onUpdate: NoAction)
  lieux           lieux?            @relation(fields: [lieu_id], references: [id], onUpdate: NoAction)

  @@index([admin_id], map: "idx_produits_admin")
  @@index([niveau_actuel], map: "idx_produits_niveau")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model transactions {
  id                                     String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  type                                   type_transaction
  categorie                              categorie_transaction
  montant                                Decimal               @db.Decimal(12, 2)
  description                            String?
  commande_id                            String?               @db.Uuid
  date_operation                         DateTime              @default(dbgenerated("CURRENT_DATE")) @db.Date
  cree_par                               String                @db.Uuid
  admin_id                               String                @db.Uuid
  cree_le                                DateTime?             @default(now()) @db.Timestamptz(6)
  comptes_transactions_admin_idTocomptes comptes               @relation("transactions_admin_idTocomptes", fields: [admin_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  commandes                              commandes?            @relation(fields: [commande_id], references: [id], onUpdate: NoAction)
  comptes_transactions_cree_parTocomptes comptes               @relation("transactions_cree_parTocomptes", fields: [cree_par], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([admin_id], map: "idx_transactions_admin")
}

model lieux {
  id        String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nom       String      @db.VarChar(150)
  adresse   String?
  ville     String?     @db.VarChar(100)
  admin_id  String      @db.Uuid
  cree_le   DateTime?   @default(now()) @db.Timestamptz(6)
  commandes commandes[]
  comptes   comptes     @relation(fields: [admin_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  produits  produits[]
}

model livraisons_livreurs {
  id             String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  bon_id         String         @db.Uuid
  livreur_id     String         @db.Uuid
  assigne_le     DateTime?      @default(now()) @db.Timestamptz(6)
  commentaire    String?
  bons_livraison bons_livraison @relation(fields: [bon_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  comptes        comptes        @relation(fields: [livreur_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum niveau_stock {
  vide
  bas
  moyen
  plein
}

enum role_compte {
  super_admin
  admin
  employe
  livreur
}

enum statut_bon {
  en_attente
  en_cours
  livre
  retour
  echoue
}

enum statut_commande {
  brouillon
  confirmee
  en_preparation
  en_livraison
  livree
  retour
  annulee
}

enum statut_compte {
  actif
  inactif
  suspendu
}

enum statut_facture {
  brouillon
  envoyee
  payee
  annulee
}

enum type_transaction {
  revenu
  depense
}

enum categorie_transaction {
  vente
  achat_stock
  salaire
  loyer
  transport
  autre
}

enum plan_abonnement {
  starter
  pro
  business
}

enum statut_abonnement {
  actif
  inactif
  suspendu
}
